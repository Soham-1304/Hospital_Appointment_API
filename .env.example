# Copy this to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Backend ──────────────────────────────────────────────────────────────────
# Local dev:
DATABASE_URL=sqlite:///./hospital.db
# Production (Render injects this automatically via the Blueprint):
# DATABASE_URL=postgresql://user:pass@host:5432/hospital

APP_NAME=Hospital Appointment System
DEBUG=true
API_PREFIX=/graphql

# ── Shared ───────────────────────────────────────────────────────────────────
# Used by frontend (local) and test script to build the GraphQL URL
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
